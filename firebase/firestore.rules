rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admins collection
    match /admins/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    // Quizzes collection (public read, admin write)
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // Questions collection (public read, admin write)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // Attempts collection (users can read/write their own, admins can read all)
    match /attempts/{attemptId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.userId;
      allow write: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings collection (public read, admin write)
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
